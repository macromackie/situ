{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "projects/**/*.test.ts",
    "projects/**/*.test.tsx",
    "projects/app/packages/reports-ui/.storybook/main.ts",
    "projects/app/packages/reports-ui/stories/**/*.stories.tsx",
    "projects/app/.storybook/main.ts",
    "projects/app/src/**/*.stories.tsx",
    "projects/app/src/client/main.tsx",
    "projects/evals/evalite.config.ts",
    "projects/evals/src/**/*.eval.ts",
    "projects/evals/src/harness/situ-cli.ts",
    "scripts/**/*.test.ts"
  ],
  "ignoreDependencies": [
    "@fontsource-variable/inter",
    "@fontsource-variable/jetbrains-mono",
    "@fontsource-variable/source-serif-4",
    "@situ/common",
    "@situ/errors",
    "luxon"
  ],
  "ignorePatterns": [
    ".fallow/**",
    "node_modules/**",
    "dist/**",
    "coverage/**",
    "bun.lock",
    "projects/evals/workspaces/**"
  ],
  "rules": {
    "unused-files": "error",
    "unused-exports": "error",
    "unused-types": "error",
    "unused-dependencies": "error",
    "unused-dev-dependencies": "error",
    "unused-optional-dependencies": "error",
    "unused-enum-members": "error",
    "unused-class-members": "error",
    "unresolved-imports": "error",
    "unlisted-dependencies": "error",
    "duplicate-exports": "error",
    "type-only-dependencies": "error",
    "test-only-dependencies": "error",
    "circular-dependencies": "error",
    "boundary-violation": "error",
    "stale-suppressions": "error",
    "unused-catalog-entries": "error",
    "unresolved-catalog-references": "error",
    "unused-dependency-overrides": "error",
    "misconfigured-dependency-overrides": "error"
  },
  "workspaces": {
    "packages": [
      "projects/app",
      "projects/app/packages/*",
      "projects/e2e-tests",
      "projects/e2e-tests/packages/*",
      "projects/evals",
      "projects/evals/packages/*"
    ]
  }
}
